# ===== DATABASE =====
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cryptoai
REDIS_URL=redis://localhost:6379

# ===== API KEYS =====
COINGECKO_API_KEY=           # Optional (improves rate limit)
COINMARKETCAP_API_KEY=       # Required for Phase 8 CMC collector (cmc_rank, tags, category, price data)
GITHUB_TOKEN=                # Required for dev activity
TWITTER_BEARER_TOKEN=        # Optional — Phase 8 social signals (Twitter Basic plan ~$100/mo)
GEMINI_API_KEY=              # For Gemini LLM
OPENAI_API_KEY=              # Optional, paid fallback
TELEGRAM_BOT_TOKEN=          # For alerts
TELEGRAM_CHAT_ID=            # Your chat ID

# ===== LLM PROVIDER =====
LLM_PRIMARY=ollama
LLM_FALLBACK=gemini
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ===== ANALYSIS =====
TOKENS_TO_ANALYZE=300
ANALYSIS_CURRENCY=USD
COINGECKO_VS_CURRENCY=usd

# ===== SCHEDULER =====
REALTIME_INTERVAL_MINUTES=30
DAILY_RUN_HOUR=6
WEEKLY_RUN_DAY=monday
MONTHLY_RUN_DAY=1

# ===== ALERTS =====
ALERT_LISTING_THRESHOLD=0.70
ALERT_WHALE_ACCUMULATION_THRESHOLD=7.0
ALERT_MEMECOIN_SOCIAL_GROWTH=500

# ===== FRONTEND =====
VITE_API_BASE_URL=http://localhost:8000
